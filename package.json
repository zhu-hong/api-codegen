{
	"name": "@zhuh/oig",
	"description": "从 OpenAPI/Swagger 规范自动生成 TypeScript API 客户端",
	"keywords": [
		"openapi",
		"swagger",
		"typescript",
		"codegen",
		"api",
		"client",
		"axios",
		"orval",
		"generator",
		"cli"
	],
	"private": false,
	"version": "8.9.1",
	"type": "module",
	"bin": {
		"@zhuh/oig": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c ./rollup.config.ts --configImportAttributesKey with",
		"format": "biome check --write . --use-editorconfig=true",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepublishOnly": "pnpm format && bumpp && pnpm build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-replace": "^6.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.5",
		"axios": "^1.16.0",
		"bumpp": "^11.1.0",
		"openapi3-ts": "^4.5.0",
		"rollup": "^4.60.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"@orval/core": "^8.9.1",
		"@zhuh/orval": "8.9.1",
		"del": "^8.0.1",
		"execa": "^9.6.1",
		"p-limit": "^7.3.0",
		"picocolors": "^1.1.1"
	},
	"resolutions": {
		"whatwg-url": "16.0.1"
	},
	"overrides": {
		"whatwg-url": "16.0.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	}
}
