{
	"name": "openapi-tsgen",
	"private": false,
	"version": "0.0.0",
	"type": "module",
	"bin": {
		"openapi-tsgen": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c ./rollup.config.ts --configImportAttributesKey with",
		"format": "biome check --write . --use-editorconfig=true",
		"prepublishOnly": "pnpm format && bumpp && pnpm build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-replace": "^6.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^25.6.0",
		"axios": "^1.16.0",
		"bumpp": "^11.1.0",
		"openapi3-ts": "^4.5.0",
		"rollup": "^4.60.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"@orval/core": "^8.9.1",
		"@zhuh/orval": "8.9.1",
		"del": "^8.0.1",
		"execa": "^9.6.1",
		"p-limit": "^7.3.0",
		"picocolors": "^1.1.1"
	},
	"resolutions": {
		"whatwg-url": "16.0.1"
	},
	"overrides": {
		"whatwg-url": "16.0.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	}
}
